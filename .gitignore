# ============================================================
# LLM-Keyring .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# PyInstaller
build/
dist/
*.spec

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# OS-specific
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# User-specific
*.local

# User whitelist (persisted managed-keys list — DO NOT commit user data)
managed_keys.json